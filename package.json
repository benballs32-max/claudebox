{
  "name": "claudebox",
  "version": "1.0.0",
  "description": "Stream Deck triggered Claude vision assistant",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "net.zavtech.claudebox",
    "productName": "ClaudeBox",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClaudeBox"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
