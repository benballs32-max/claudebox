{
  "name": "claudebox",
  "version": "1.0.0",
  "description": "Stream Deck triggered Claude vision assistant",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:signed": "powershell -ExecutionPolicy Bypass -File scripts/build-signed.ps1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "net.zavtech.claudebox",
    "productName": "ClaudeBox",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClaudeBox"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "benballs32-max",
      "repo": "claudebox"
    }
  }
}
